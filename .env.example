# Copy this file to .env and fill the keys you want to use.
# Local paths (optional: defaults are auto-resolved if left empty)
FIUBA_ROOT=
FIUBA_STATE_DIR=
FIUBA_DB_PATH=

# OpenAI
OPENAI_API_KEY=

# Gemini
GEMINI_API_KEY=

# Optional defaults for local UI runtime
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
